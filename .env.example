# Zoho SMTP credentials for /api/contact
# Copy this file to .env.local and fill in real values for local development.
# In production, set these in your hosting provider (e.g. Vercel project env vars).
#
# ZOHO_PASSWORD should be an app-specific password, not your account password.
# Generate one in Zoho Mail: Settings → Security → App Passwords.

ZOHO_EMAIL=you@yourdomain.com
ZOHO_PASSWORD=your-app-specific-password
